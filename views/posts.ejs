<%- include('partials/header', { title, user: user }) %>

<div class="container mt-4">
  <h1 class="text-center mb-4">All Posts</h1>

  <!-- Search Bar -->
  <form action="/posts" method="GET" class="mb-4">
    <div class="input-group">
      <input
        type="text"
        class="form-control"
        name="search"
        placeholder="Search posts by title..."
        value="<%= search %>"
      />
      <button class="btn btn-primary" type="submit"><i class="fas fa-search"></i> Search</button>
      <% if (search) { %>
      <a href="/posts" class="btn btn-outline-secondary">Clear</a>
      <% } %>
    </div>
  </form>

  <% if (search) { %>
  <p class="text-muted">Showing results for: <strong><%= search %></strong> (<%= posts.length %> found)</p>
  <% } %>

  <div class="row">
    <% if (posts.length > 0) { %>
    <% posts.forEach(post => { %>
    <div class="col-12 col-md-6 col-lg-4 mb-4 d-flex">
      <div class="card h-100 w-100">
        <% if (post.images && post.images.length > 0) { %>
        <img src="<%= post.images[0].url %>" class="card-img-top post-card-image" alt="Post Image" />
        <% } %>
        <div class="card-body d-flex flex-column">
          <h5 class="card-title"><%= post.title %></h5>
          <p class="card-text text-muted">
            by <%= post.author.username %> &bull; <%= post.createdAt.toDateString() %>
          </p>
          <a href="/posts/<%= post._id %>" class="btn btn-primary mt-auto">Read More</a>
        </div>
      </div>
    </div>
    <% }) %>
    <% } else { %>
    <p class="text-center w-100">No posts found.</p>
    <% } %>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
  <nav class="mt-4">
    <ul class="pagination justify-content-center">
      <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
        <a class="page-link" href="/posts?page=<%= currentPage - 1 %>&search=<%= search %>">Previous</a>
      </li>
      <% for (let i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= i === currentPage ? 'active' : '' %>">
        <a class="page-link" href="/posts?page=<%= i %>&search=<%= search %>"><%= i %></a>
      </li>
      <% } %>
      <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
        <a class="page-link" href="/posts?page=<%= currentPage + 1 %>&search=<%= search %>">Next</a>
      </li>
    </ul>
  </nav>
  <% } %>
</div>

<%- include('partials/footer') %>
