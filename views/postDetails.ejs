<%- include('partials/header', { title: 'Post Details', user: user }) %>

<div class="container mt-5">
  <% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
  <% } %>
  <% if (success) { %>
  <div class="alert alert-success"><%= success %></div>
  <% } %>

  <% if (!post) { %>
  <div class="alert alert-warning">Post not found.</div>
  <a href="/posts" class="btn btn-secondary">Back to Posts</a>
  <% } else { %>
  <div class="row">
    <div class="col-lg-8 offset-lg-2">
      <div class="card mb-4">
        <% if (post.images && post.images.length > 0) { %>
        <div id="postCarousel" class="carousel slide" data-bs-ride="carousel">
          <div class="carousel-inner">
            <% post.images.forEach((image, index) => { %>
            <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
              <img src="<%= image.url %>" class="d-block w-100" alt="Post Image" style="max-height:400px; object-fit:cover;" />
            </div>
            <% }) %>
          </div>
          <% if (post.images.length > 1) { %>
          <button class="carousel-control-prev" type="button" data-bs-target="#postCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#postCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
          </button>
          <% } %>
        </div>
        <% } %>

        <div class="card-body">
          <h1 class="card-title"><%= post.title %></h1>
          <p class="text-muted mb-2">
            by <strong><%= post.author.username %></strong> on <%= post.createdAt.toDateString() %>
          </p>
          <p class="card-text"><%= post.content %></p>

          <!-- Like Button -->
          <div class="mb-3">
            <% if (user) { %>
            <% const liked = post.likes && post.likes.some(l => l._id.toString() === user._id.toString()); %>
            <button
              id="likeBtn"
              class="btn <%= liked ? 'btn-danger' : 'btn-outline-danger' %>"
              onclick="toggleLike('<%= post._id %>')"
            >
              <i class="fas fa-heart"></i>
              <span id="likeCount"><%= post.likes ? post.likes.length : 0 %></span>
              <%= liked ? 'Liked' : 'Like' %>
            </button>
            <% } else { %>
            <span class="text-muted"><i class="fas fa-heart text-danger"></i> <%= post.likes ? post.likes.length : 0 %> likes</span>
            <% } %>
          </div>

          <% if (user && post.author && user._id.toString() === post.author._id.toString()) { %>
          <div class="mb-3">
            <a href="/posts/<%= post._id %>/edit" class="btn btn-outline-primary me-2">Edit Post</a>
            <form action="/posts/<%= post._id %>?_method=DELETE" method="POST" class="d-inline">
              <button type="submit" class="btn btn-danger">Delete Post</button>
            </form>
          </div>
          <% } %>

          <hr />
          <h4>Comments (<%= post.comments ? post.comments.length : 0 %>)</h4>
          <% if (post.comments && post.comments.length > 0) { %>
          <% post.comments.forEach(comment => { %>
          <div class="card mb-3">
            <div class="card-body">
              <p class="card-text"><%= comment.content %></p>
              <p class="text-muted mb-1">
                by <strong><%= comment.author.username %></strong>
                <small><%= comment.createdAt ? new Date(comment.createdAt).toDateString() : '' %></small>
              </p>
              <% if (user && comment.author && user._id.toString() === comment.author._id.toString()) { %>
              <div>
                <a href="/comments/<%= comment._id %>/edit" class="btn btn-sm btn-outline-secondary me-2">Edit</a>
                <form action="/comments/<%= comment._id %>?_method=DELETE" method="POST" class="d-inline">
                  <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
              </div>
              <% } %>
            </div>
          </div>
          <% }) %>
          <% } else { %>
          <p>No comments yet. Be the first to comment!</p>
          <% } %>

          <% if (user) { %>
          <form action="/posts/<%= post._id %>/comments" method="POST">
            <div class="mb-3">
              <label for="content" class="form-label">Add a comment</label>
              <textarea class="form-control" id="content" name="content" rows="3" maxlength="500" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Post Comment</button>
          </form>
          <% } else { %>
          <p class="mt-3"><a href="/login">Login</a> to leave a comment.</p>
          <% } %>

          <a href="/posts" class="btn btn-secondary mt-4">Back to Posts</a>
        </div>
      </div>
    </div>
  </div>
  <% } %>
</div>

<script>
async function toggleLike(postId) {
  const res = await fetch(`/posts/${postId}/like`, { method: 'POST' });
  const data = await res.json();
  document.getElementById('likeCount').textContent = data.likes;
  const btn = document.getElementById('likeBtn');
  if (data.liked) {
    btn.classList.remove('btn-outline-danger');
    btn.classList.add('btn-danger');
    btn.innerHTML = `<i class="fas fa-heart"></i> <span id="likeCount">${data.likes}</span> Liked`;
  } else {
    btn.classList.remove('btn-danger');
    btn.classList.add('btn-outline-danger');
    btn.innerHTML = `<i class="fas fa-heart"></i> <span id="likeCount">${data.likes}</span> Like`;
  }
}
</script>

<%- include('partials/footer') %>
